{
  "tasks": {
    "check": "deno check src/**/*.ts scripts/**/*.ts tests/**/*.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "test": "deno test --allow-read --allow-write --allow-env --allow-run --allow-ffi",
    "ok": "deno task fmt:check && deno task lint && deno task check && deno task test",
    "build-release": "deno run --allow-read --allow-write --allow-env --allow-ffi scripts/dc.ts release build",
    "dc": "deno run --allow-read --allow-write --allow-env --allow-net --allow-ffi scripts/dc.ts"
  },
  "imports": {
    "@db/sqlite": "jsr:@db/sqlite@0.13.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/fs": "jsr:@std/fs@1",
    "@std/path": "jsr:@std/path@1"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "exclude": ["require-await"]
    }
  }
}
