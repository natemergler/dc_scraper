{
  "tasks": {
    "check": "deno check src/**/*.ts scripts/**/*.ts tests/**/*.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-run --allow-net --allow-ffi",
    "fmt": "deno fmt",
    "validate": "deno run --allow-read --allow-write scripts/dc.ts validate",
    "generate-checks": "deno run --allow-read --allow-write scripts/dc.ts checks generate",
    "build-release": "deno run --allow-read --allow-write --allow-run scripts/dc.ts release build",
    "dc": "deno run --allow-read --allow-write --allow-env --allow-run --allow-net --allow-ffi scripts/dc.ts"
  },
  "imports": {
    "@db/sqlite": "jsr:@db/sqlite@0.13.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/fs": "jsr:@std/fs@1",
    "@std/path": "jsr:@std/path@1",
    "@std/yaml": "jsr:@std/yaml@1"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  }
}
